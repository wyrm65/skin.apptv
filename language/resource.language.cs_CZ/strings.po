msgctxt "#31300"
msgid "Select type of image to display at startup."
msgstr "Vyberte typ obrázku, který se má zobrazit při spuštění."

msgctxt "#31301"
msgid "Location of custom image or video to display on startup screen."
msgstr "Umístění vlastního obrázku nebo videa, které se má zobrazit na obrazovce při spuštění."

msgctxt "#31302"
msgid "Play custom playlist at startup."
msgstr "Při spuštění přehrát vlastní seznam stop."

msgctxt "#31303"
msgid "Location of custom startup playlist."
msgstr "Umístění vlastního seznamu stop pro spuštění."

msgctxt "#31304"
msgid "Don't show Screen settings menus (know as side bar menu in some skins)."
msgstr "Nezobrazovat nabídky nastavení obrazovky (v některých vzhledech označované jako postranní nabídka)."

msgctxt "#31305"
msgid "Select when to show scrollbar."
msgstr "Vyberte, kdy se má zobrazovat posuvník."

msgctxt "#31306"
msgid "Scroll label or textbox contents when length of field exceeds defined length."
msgstr "Posouvat text popisku nebo textového pole, pokud délka pole překročí definovanou délku."

msgctxt "#31307"
msgid "Show playing media details for playing media."
msgstr "Zobrazovat podrobnosti o právě přehrávaném médiu."

msgctxt "#31308"
msgid "Display a media case around Album or Video cover icon."
msgstr "Zobrazovat kolem ikony obalu alba nebo videa rámeček média."

msgctxt "#31309"
msgid "Letterbar allows user to click first letter of media item name to navigate to library starting at clicked letter. Sorry, English only."
msgstr "Abecední panel umožňuje kliknout na první písmeno názvu položky média a přejít v knihovně na položky začínající vybraným písmenem. Bohužel pouze v angličtině."

msgctxt "#31310"
msgid "Display touch/mouse controls if Kodi running on a touch/mouse enabled system."
msgstr "Zobrazovat dotykové/myší ovládací prvky, pokud Kodi běží v systému s dotykovým ovládáním nebo myší."

msgctxt "#31315"
msgid "Type of image(s) to use on Movie shelf (On Horizontal or Icon menu type only)."
msgstr "Typ obrázků pro panel filmů (pouze pro vodorovný typ nabídky nebo nabídku s ikonami)."

msgctxt "#31316"
msgid "Type of image(s) to use on TVShows shelf (On Horizontal or Icon menu type only)."
msgstr "Typ obrázků pro panel seriálů (pouze pro vodorovný typ nabídky nebo nabídku s ikonami)."

msgctxt "#31317"
msgid "Subtype of image(s) to use on TVShows shelf."
msgstr "Podtyp obrázků pro panel seriálů."

msgctxt "#31318"
msgid "Type of image(s) to use on Music shelf (On Horizontal or Icon menu type only)."
msgstr "Typ obrázků pro panel hudby (pouze pro vodorovný typ nabídky nebo nabídku s ikonami)."

msgctxt "#31319"
msgid "Type of image(s) to use on Add-ons shelf (On Horizontal or Icon menu type only)."
msgstr "Typ obrázků pro panel doplňků (pouze pro vodorovný typ nabídky nebo nabídku s ikonami)."

msgctxt "#31320"
msgid "Type of image(s) to use on Broadcast shelf (On Horizontal or Icon menu type only)."
msgstr "Typ obrázků pro panel vysílání (pouze pro vodorovný typ nabídky nebo nabídku s ikonami)."

# empty string with id 31321
msgctxt "#31322"
msgid "Type of image(s) to use on Custom shelf (On Horizontal or Icon menu type only)."
msgstr "Typ obrázků pro vlastní panel (pouze pro vodorovný typ nabídky nebo nabídku s ikonami)."

msgctxt "#31323"
msgid "Play theme tune if available (theme file can be either MP3 or Flac format)"
msgstr "Přehrávat znělku, pokud je dostupná (soubor znělky může být ve formátu MP3 nebo FLAC)"

msgctxt "#31324"
msgid "Locale of Certification ratings"
msgstr "Oblast věkového hodnocení"

msgctxt "#31325"
msgid "Type of widget to use on Movie Video Info screen."
msgstr "Typ widgetu pro obrazovku informací o filmu."

msgctxt "#31326"
msgid "Type of widget to use on TVShows Video Info screen."
msgstr "Typ widgetu pro obrazovku informací o seriálu."

msgctxt "#31327"
msgid "Type of Certification ratings to show (Icon, Text or None)"
msgstr "Typ zobrazovaného věkového hodnocení (ikona, text nebo žádné)"

# empty strings from id 31327 to 31339
msgctxt "#31340"
msgid "Location of custom skin background image."
msgstr "Umístění vlastního obrázku na pozadí vzhledu."

msgctxt "#31341"
msgid "Use FanArt image if available as skin background image."
msgstr "Použít obrázek fanartu jako obrázek na pozadí vzhledu, pokud je dostupný."

# empty string with id 31342
msgctxt "#31343"
msgid "Use Playing video or Music visualisation if available as skin background image."
msgstr "Použít přehrávané video nebo hudební vizualizaci jako pozadí vzhledu, pokud jsou dostupné."

msgctxt "#31344"
msgid "Use Artistslideshow script to provide Music Artist FanArt image if available as skin background image."
msgstr "Použít skript Artist Slideshow k poskytnutí fanartu hudebního interpreta jako obrázku na pozadí vzhledu, pokud je dostupný."

# empty string with id 31345
msgctxt "#31346"
msgid "Set level of visibilty of background image."
msgstr "Nastavuje úroveň viditelnosti obrázku na pozadí."

# empty strings from id 31347 to 31349
msgctxt "#31350"
msgid "Set location to enter Movie library when Movie item selected on home menu screen."
msgstr "Nastavuje umístění v knihovně filmů, které se otevře po výběru položky Filmy na domovské obrazovce."

msgctxt "#31351"
msgid "Set location to enter TVShow library when TVShow item selected on home menu screen."
msgstr "Nastavuje umístění v knihovně seriálů, které se otevře po výběru položky Seriály na domovské obrazovce."

msgctxt "#31352"
msgid "Set location to enter Music Video library when Music Video item selected on home menu screen."
msgstr "Nastavuje umístění v knihovně hudebních videí, které se otevře po výběru položky Hudební videa na domovské obrazovce."

msgctxt "#31353"
msgid "Set location to enter Music library when Music item selected on home menu screen."
msgstr "Nastavuje umístění v knihovně hudby, které se otevře po výběru položky Hudba na domovské obrazovce."

msgctxt "#31354"
msgid "Set location to enter Broardcast TV library when TV item selected on home menu screen."
msgstr "Nastavuje umístění v knihovně televizního vysílání, které se otevře po výběru položky TV na domovské obrazovce."

msgctxt "#31355"
msgid "Set location to enter Broadcast Radio library when Radio item selected on home menu screen."
msgstr "Nastavuje umístění v knihovně rádiového vysílání, které se otevře po výběru položky Rádio na domovské obrazovce."

# empty strings from id 31356 to 31358
msgctxt "#31359"
msgid "Additional addons to extend the usabilty of the skin."
msgstr "Další doplňky pro rozšíření použitelnosti vzhledu."

msgctxt "#31360"
msgid "Sub menu to assign custom shortcuts and change visible state of home menu items."
msgstr "Podnabídka pro přiřazení vlastních zkratek a změnu viditelnosti položek domovské nabídky."

msgctxt "#31361"
msgid "Script downloads and allows the display of additional artist fanart images for the currently playing song."
msgstr "Skript stahuje a umožňuje zobrazovat další obrázky fanartu interpreta pro právě přehrávanou skladbu."

msgctxt "#31362"
msgid "Script to play theme tune for selected media item."
msgstr "Skript pro přehrávání znělky vybrané položky média."

msgctxt "#31363"
msgid "Script adds a list of suggestions for current text entered in the on screen keyboard."
msgstr "Skript přidává seznam návrhů pro aktuální text zadaný na klávesnici na obrazovce."

msgctxt "#31364"
msgid "Script allows user to download and display song lyrics for the currently playing song."
msgstr "Skript umožňuje stahovat a zobrazovat texty právě přehrávané skladby."

msgctxt "#31365"
msgid "Script provides a much improved search facility from the basic version supplied with Kodi."
msgstr "Skript poskytuje výrazně vylepšené vyhledávání oproti základní verzi dodávané s Kodi."

msgctxt "#31366"
msgid "Script allows user to load custom icons and background images for use thruout the skin."
msgstr "Skript umožňuje načítat vlastní ikony a obrázky na pozadí pro použití v celém vzhledu."

msgctxt "#31367"
msgid "Script gives user the option to play next episode of current TV show."
msgstr "Skript nabízí možnost přehrát další epizodu aktuálního seriálu."

msgctxt "#31368"
msgid "Script used to provide a listing of upcomming TV episodes. User must still provide a link to the script via the skins home customisation screen."
msgstr "Skript používaný k poskytnutí seznamu nadcházejících epizod seriálů. Uživatel musí i tak doplnit odkaz na skript prostřednictvím obrazovky přizpůsobení domovské obrazovky vzhledu."

msgctxt "#31370"
msgid "Use Debug log uploader script to post a debug log ('Full' debug logging must be turned on before log can be posted)."
msgstr "Použít skript Debug Log Uploader k odeslání ladicího protokolu (před odesláním protokolu musí být zapnuté „úplné“ ladicí protokolování)."

msgctxt "#31371"
msgid "Turn on 'Full' debug log."
msgstr "Zapnout „úplné“ ladicí protokolování."

msgctxt "#31372"
msgid "Turn on debug grid overlay to help users locate on screen skin items."
msgstr "Zapnout překryv ladicí mřížky, který pomáhá najít položky vzhledu na obrazovce."

msgctxt "#31373"
msgid "Turn on debug info overlay to help users identify currently displayed windows and focused screen items."
msgstr "Zapnout překryv ladicích informací, který pomáhá rozpoznat aktuálně zobrazená okna a položky obrazovky se zaměřením."

msgctxt "#31374"
msgid "Click shortcut button to assign home screen shortcut."
msgstr "Kliknutím na tlačítko zkratky přiřadíte zkratku domovské obrazovky."

msgctxt "#31375"
msgid "This button requires an active PVR client addon before it can be assigned to home screen shortcut."
msgstr "Toto tlačítko vyžaduje aktivní doplněk klienta PVR, než ho bude možné přiřadit ke zkratce domovské obrazovky."

msgctxt "#31376"
msgid "This button requires an active Weather client addon before it can be assigned to home screen shortcut."
msgstr "Toto tlačítko vyžaduje aktivní doplněk klienta počasí, než ho bude možné přiřadit ke zkratce domovské obrazovky."

